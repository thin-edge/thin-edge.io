#!/bin/bash

set -euo pipefail

usage() {
    echo "Usage: $0 <command> [args...]"
    echo "Commands:"
    echo "  list                                    List all config types supported by this plugin"
    echo "  get <type> <target-file-path>           Get config for the specified type and write to the target path"
    echo "  set <type> <new-config-path>            Set config for the specified type with the new config path"
    echo "  finalize <type>                         Perform any finalization steps after setting the config"
    exit 1
}

list_config_types() {
    echo hello.conf
}

get_config() {
    local config_type="$1"
    local target_path="$2"

    if [[ "$config_type" != "hello.conf" ]]; then
        echo "Error: Unsupported config type '$config_type'" >&2
        exit 1
    fi

    cp /etc/hello.conf  $target_path
}

set_config() {
    local config_type="$1"
    local target_config="$2"

    if [[ "$config_type" != "hello.conf" ]]; then
        echo "Error: Unsupported config type '$config_type'" >&2
        exit 1
    fi
    mv $target_config /etc/hello.conf
}

finalize_config() {
    local config_type="$1"

    if [[ "$config_type" != "hello.conf" ]]; then
        echo "Error: Unsupported config type '$config_type'" >&2
        exit 1
    fi
    systemctl restart hello
}

main() {
    if [[ $# -lt 1 ]]; then
        usage
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        "list")
            list_config_types
            ;;
        "get")
            if [[ $# -lt 2 ]]; then
                echo "Error: 'get' command requires <type> and <target-file-path> arguments" >&2
                exit 1
            fi
            get_config "$@"
            ;;
        "set")
            if [[ $# -lt 2 ]]; then
                echo "Error: 'set' command requires <type> and <new-config-path> arguments" >&2
                exit 1
            fi
            set_config "$@"
            ;;
        "finalize")
            if [[ $# -lt 1 ]]; then
                echo "Error: 'finalize' command requires a <type> argument" >&2
                exit 1
            fi
            finalize_config "$@"
            ;;
        *)
            echo "Error: Unknown command '$command'" >&2
            usage
            ;;
    esac
}

main "$@"