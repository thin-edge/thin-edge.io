#!/bin/sh
set -e

command_exists() {
    command -V "$1" >/dev/null 2>&1
}

group_exists() {
    name="$1"
    if command_exists id; then
        id -g "$name" >/dev/null 2>&1
    elif command_exists getent; then
        getent group "$name" >/dev/null 2>&1
    else
        # Fallback to plain grep, as busybox does not have getent
        grep -q "^${name}:" /etc/group
    fi
}

user_exists() {
    name="$1"
    if command_exists id; then
        id -u "$name" >/dev/null 2>&1
    elif command_exists getent; then
        getent passwd "$name" >/dev/null 2>&1
    else
        # Fallback to plain grep, as busybox does not have getent
        grep -q "^${name}:" /etc/passwd
    fi
}

# Parse a TOML string value from system.toml and provides a default value
# when no valid entry is found. Note, an empty value is classed as being found.
parse_toml_string_value() {
    property="$1"
    file_path="$2"
    default_value="$3"
    # Match first line of the form: key = "value" (strict: double-quoted string, nothing else)
    MATCHES=$(grep -E "^[[:space:]]*${property}[[:space:]]*=[[:space:]]*\"[^\"]*\"[[:space:]]*$" "$file_path" | head -n1)
    if [ -n "$MATCHES" ]; then
        # property is defined, so respect all values, even empty ones
        echo "$MATCHES" | sed 's/.*=[[:space:]]*"\([^"]*\)".*/\1/'
    else
        # not-defined so the given default value
        echo "Using default as no valid value for '$property' was found in '$file_path'" >&2
        echo "$default_value"
    fi
}

# Read user/group from /etc/tedge/system.toml if it exists
TEDGE_USER="tedge"
TEDGE_GROUP="tedge"
SYSTEM_TOML="/etc/tedge/system.toml"
if [ -f "$SYSTEM_TOML" ]; then
    TEDGE_USER=$(parse_toml_string_value "user" "$SYSTEM_TOML" "$TEDGE_USER")
    TEDGE_GROUP=$(parse_toml_string_value "group" "$SYSTEM_TOML" "$TEDGE_GROUP")
fi

### Create groups
# Only create the group automatically when using the default "tedge" group.
# A custom group is expected to be created by the user before or after installation.
if [ "$TEDGE_GROUP" = "tedge" ]; then
    if ! group_exists tedge; then
        if command_exists groupadd; then
            groupadd --system tedge
        elif command_exists addgroup; then
            addgroup -S tedge
        else
            echo "WARNING: Could not create group: tedge" >&2
        fi
    fi
fi

### Create users
# Only create the user automatically when using the default "tedge" user.
# A custom user is expected to be created by the user before or after installation.
if [ "$TEDGE_USER" = "tedge" ]; then
    if ! user_exists tedge; then
        if command_exists useradd; then
            useradd --system --no-create-home --shell /sbin/nologin --gid "$TEDGE_GROUP" "$TEDGE_USER"
        elif command_exists adduser; then
            adduser -g "" -H -D tedge -G tedge
        else
            echo "WARNING: Could not create user: tedge" >&2
        fi
    fi
fi

### Create file in /etc/sudoers.d directory. With this configuration,
###the configured user has the right to call the tedge command with sudo rights,
### which is required for system-wide configuration in "/etc/tedge"
if [ "$TEDGE_USER" = "tedge" ] && [ -d /etc/sudoers.d ]; then
    {
        echo "tedge    ALL = (ALL) NOPASSWD:SETENV: /usr/bin/tedge, /etc/tedge/sm-plugins/[a-zA-Z0-9]*, /bin/sync, /sbin/init"
        echo "tedge    ALL = (ALL) NOPASSWD:SETENV: /usr/bin/tedge-write /etc/*"
        echo "tedge    ALL = (ALL) NOPASSWD:SETENV: /usr/share/tedge/log-plugins/[a-zA-Z0-9]*"
        echo "tedge    ALL = (ALL) NOPASSWD:SETENV: /usr/share/tedge/config-plugins/[a-zA-Z0-9]*"
    } > /etc/sudoers.d/tedge
fi


# change the ownership of the below directories/files to the configured user.
# Skip if the user does not exist yet; ownership can be set later via 'tedge init'.
if user_exists "$TEDGE_USER" && group_exists "$TEDGE_GROUP"; then

    if [ -d "/etc/tedge/operations/c8y" ]; then
        chown "$TEDGE_USER:$TEDGE_GROUP" /etc/tedge/operations/c8y

        # Don't fail if there are no files found
        chown "$TEDGE_USER:$TEDGE_GROUP" /etc/tedge/operations/c8y/c8y_* 2>/dev/null ||:
    fi

    if [ -d "/etc/tedge/operations/az" ]; then
        chown "$TEDGE_USER:$TEDGE_GROUP" /etc/tedge/operations/az
    fi

    if [ -d "/etc/tedge/operations/aws" ]; then
        chown "$TEDGE_USER:$TEDGE_GROUP" /etc/tedge/operations/aws
    fi

    if [ -d "/etc/tedge/.agent/" ]; then
        chown "$TEDGE_USER:$TEDGE_GROUP" /etc/tedge/.agent
    fi

    if [ -d "/var/log/tedge/agent/" ]; then
        chown "$TEDGE_USER:$TEDGE_GROUP" /var/log/tedge/agent
    fi

    if [ -f "/run/lock/tedge_agent.lock" ]; then
        chown "$TEDGE_USER:$TEDGE_GROUP" /run/lock/tedge_agent.lock
    fi

    if [ -f "/run/lock/tedge-agent.lock" ]; then
        chown "$TEDGE_USER:$TEDGE_GROUP" /run/lock/tedge-agent.lock
    fi

    if [ -f "/run/lock/tedge-mapper-c8y.lock" ]; then
        chown "$TEDGE_USER:$TEDGE_GROUP" /run/lock/tedge-mapper-c8y.lock
    fi

    if [ -f "/run/lock/tedge-mapper-az.lock" ]; then
        chown "$TEDGE_USER:$TEDGE_GROUP" /run/lock/tedge-mapper-az.lock
    fi

    if [ -f "/run/lock/tedge-mapper-aws.lock" ]; then
        chown "$TEDGE_USER:$TEDGE_GROUP" /run/lock/tedge-mapper-aws.lock
    fi

fi # end: user_exists && group_exists
